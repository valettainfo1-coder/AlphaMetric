# AlphaMetric — Environment Variables
# Copy to .env.local locally. In Vercel: Project Settings → Environment Variables.

# --- REQUIRED ---
# Finnhub (quotes, search, fundamentals) — https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# Groq (Metrio AI) — https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# --- OPTIONAL FALLBACKS ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
