# ═══════════════════════════════════════════════════════════════════
# AlphaMetric — Environment Variables
# Kopiere diese Datei zu `.env.local` und fülle die Werte aus.
# Für Vercel/Netlify: im Dashboard unter "Environment Variables" eintragen.
# ═══════════════════════════════════════════════════════════════════

# ── Primary LLM (required for Metrio AI) ──────────────────────────
# Hol dir einen Key auf https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Market Data (recommended) ─────────────────────────────────────
# https://finnhub.io — Free tier reicht für Dev
FINNHUB_API_KEY=

# ── Optional LLM Fallbacks ────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# ── Optional Python Backend (legacy, not required) ────────────────
# Leer lassen, außer eigener Flask-Server läuft.
FLASK_BACKEND_URL=

# ── Public site URL (für SEO / OG-Tags) ───────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
